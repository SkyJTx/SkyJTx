{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "forceConsistentCasingInFileNames": true,
    "allowImportingTsExtensions": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "allowJs": true,
    "strict": true,
    "noEmit": true,
    "types": [
      "vite/client"
    ],
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "~/*": [
        "./src/*"
      ],
      "@skyjt/signals-solid": [
        "../../packages/signals-solid/src/index.ts"
      ],
      "@skyjt/query-solid": [
        "../../packages/query-solid/src/index.ts"
      ],
      "@skyjt/store-solid": [
        "../../packages/store-solid/src/index.ts"
      ]
    }
  }
}