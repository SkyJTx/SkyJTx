{
  "compilerOptions": {
    "forceConsistentCasingInFileNames": true,
    "lib": [
      "ESNext"
    ],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ESNext",
    "types": [
      "bun-types",
      "node"
    ],
    "strict": true,
    "noEmit": true
  },
  "include": [
    "./**/*.ts"
  ]
}