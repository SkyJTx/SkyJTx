{
  "name": "@skyjtx/signals-solid",
  "version": "0.1.0",
  "description": "SolidJS signal helpers with a Vue-like API.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "license": "Apache-2.0",
  "author": "Nattakarn Khumsupha (SkyJT)",
  "repository": {
    "type": "git",
    "url": "https://github.com/SkyJTx/SkyJTx"
  },
  "homepage": "https://github.com/SkyJTx/SkyJTx",
  "bugs": {
    "url": "https://github.com/SkyJTx/SkyJTx/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "solid",
    "solidjs",
    "signals",
    "reactivity"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "build:js": "bun build ./src/index.ts --outdir ./dist --format esm --sourcemap",
    "build:types": "bunx tsc -p tsconfig.build.json",
    "build": "bun run build:js && bun run build:types",
    "prepublishOnly": "bun run build"
  },
  "peerDependencies": {
    "solid-js": "^1.9.5"
  },
  "devDependencies": {
    "bun-types": "^1.3.11",
    "rimraf": "^5.0.5",
    "typescript": "^5.5.4"
  }
}