{
  "name": "skyjt",
  "scripts": {
    "packages:clean": "bun run scripts/packages.ts clean",
    "packages:build": "bun run scripts/packages.ts build",
    "packages:test": "bun run scripts/packages.ts test",
    "packages:pack": "bun run scripts/packages.ts pack",
    "packages:publish:dry": "bun run scripts/packages.ts pack",
    "packages:publish": "bun run scripts/packages.ts publish",
    "web:dev": "bun --cwd apps/web dev",
    "web:build": "bun --cwd apps/web build",
    "web:start": "bun --cwd apps/web start",
    "web:preview": "bun --cwd apps/web preview"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@types/node": "^20.19.43",
    "bun-types": "^1.3.14",
    "solid-js": "^1.9.5",
    "solid-styled-components": "^0.28.5"
  }
}